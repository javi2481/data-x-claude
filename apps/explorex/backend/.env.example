# Explorex hereda la mayoría de variables del Core.
# Asegúrate de que las variables de core/backend/.env estén presentes.

# Configuración específica de Explorex
JUPYTER_SERVER_URL=http://localhost:8888 # Para el KernelManager si se integra con Jupyter real (no mock)
JUPYTER_SERVER_TOKEN=your_token_here

# Ruta al core (si no se especifica en app.py dinámicamente)
# CORE_BACKEND_PATH=../../core/backend
