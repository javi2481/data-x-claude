# Configuración de MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=explorex

# Configuración de LiteLLM y API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here # Requerido para modelos Claude y Qwen en la nube
CODER_MODEL=openrouter/anthropic/claude-3.5-sonnet
REVIEWER_MODEL=openrouter/qwen/qwen3-32b
INTERPRETER_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Timeouts y Límites
ANALYSIS_TIMEOUT_SECONDS=120
MAX_DATASET_ROWS=100000

# Configuración de Servidor y CORS
PORT=8001
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080
API_BASE=http://127.0.0.1:8001

# Configuración de Caché
CACHE_BACKEND=mongodb
CACHE_TTL_MINUTES=1440
MONGODB_URL=mongodb://localhost:27017 # URL para la base de datos de caché
